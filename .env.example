# ============================================================================
# OpenHarness 环境变量配置
# ============================================================================
# 使用方法：复制本文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================================

# ---- LLM API Keys（至少配置一个）----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- 可选 API Keys ----
# OPENROUTER_API_KEY=
# ELEVENLABS_API_KEY=

# ---- 镜像版本标签 ----
OH_VERSION_HYPERFRAMES_VERSION=v0.1.9_v0.6.98

# ---- 构建参数（通常不需要修改）----
# PYTHON_VERSION=3.11
# UV_VERSION=0.7.3
